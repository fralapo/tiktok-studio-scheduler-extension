{
  "manifest_version": 3,
  "name": "TikTok Studio Scheduler",
  "version": "2.3.1",
  "description": "Optionally apply a caption and schedule multiple TikTok Studio clips from now or a chosen date and time.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/tiktokstudio/upload*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "TikTok Studio Scheduler",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
